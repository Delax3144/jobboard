# ========================
# ЗАВИСИМОСТИ
# ========================
# Блокируем папки с модулями во всем проекте (и во фронте, и в бэке)
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ========================
# СЕКРЕТЫ И ОКРУЖЕНИЕ
# ========================
# Прячем ключи, пароли и токены (очень важно!)
.env
.env.*
!.env.example

# ========================
# ФРОНТЕНД (Vite / React)
# ========================
# Папки с готовой сборкой (Vercel соберет это сам)
dist/
build/
.eslintcache

# ========================
# БЭКЕНД (Node.js / Prisma)
# ========================
# Игнорируем загруженные юзерами файлы (аватарки и т.д.)
Backend/uploads/
# Игнорируем локальные базы данных SQLite (как было в твоем старом файле)
*.db
*.db-journal
*.sqlite
*.sqlite3

# ========================
# СИСТЕМНЫЕ ФАЙЛЫ И РЕДАКТОРЫ
# ========================
.DS_Store
Thumbs.db
.vscode/
.idea/
Backend/.agents/