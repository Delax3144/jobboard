generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model SupportTicket {
  id        String   @id @default(uuid())
  userId    String?  // Опционально, если пишет неавторизованный
  user      User?    @relation(fields: [userId], references: [id])
  name      String
  email     String
  subject   String?
  message   String
  status    String   @default("Open") // Open, In Progress, Resolved
  createdAt DateTime @default(now())
}

model User {
  id              String   @id @default(uuid())
  email           String   @unique
  passwordHash    String
  username        String   @unique
  firstName       String
  lastName        String
  phone           String?
  avatarUrl       String?
  lastActive      DateTime @default(now())
  role            String
  status          String?  @default("Open to work") // <-- ДОБАВЬ ВОТ ЭТУ СТРОЧКУ
  createdAt       DateTime @default(now())
  bio             String?
  skills          String? // Можно хранить как строку через запятую или JSON
  experience      Json?   // Для сложного списка работ лучше использовать JSON или отдельную модель
  supportTickets  SupportTicket[]

  isVerified        Boolean  @default(false) // Подтверждена ли почта
  verificationToken String?  // Секретный токен из ссылки
  resetToken        String?

  isTwoFactorEnabled Boolean @default(false)
  twoFactorSecret    String?

  jobs         Job[]    @relation("UserJobs")
  applications Application[] @relation("UserApplications")
  
  // ДОБАВИЛИ: Связь с сохраненными вакансиями
  savedJobs    SavedJob[] 

  // === НОВЫЕ ПОЛЯ НАСТРОЕК (ПРИВАТНОСТЬ И УВЕДОМЛЕНИЯ) ===
  isPublic        Boolean @default(true)
  showEmail       Boolean @default(false)
  soundEnabled    Boolean @default(true)
  toastsEnabled   Boolean @default(true)
  
  resumeUrl       String?
  location        String?
}

model Job {
  id          String    @id @default(uuid())
  ownerId     String
  owner       User      @relation("UserJobs", fields: [ownerId], references: [id])

  title       String
  companyName String
  location    String?
  level       String    @default("Junior")
  salaryFrom  Int?
  salaryTo    Int?
  description String
  tags        String    @default("") 
  status      String    @default("published") 
  companyLogo String?
  createdAt   DateTime  @default(now())
  
  applications Application[]
  
  // ДОБАВИЛИ: Связь с пользователями, которые сохранили вакансию
  savedBy      SavedJob[] 
}

// НОВАЯ ТАБЛИЦА: Избранные вакансии
model SavedJob {
  id        String   @id @default(uuid())
  
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  jobId     String
  job       Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  
  createdAt DateTime @default(now())

  // Защита от дублей: один юзер может сохранить конкретную вакансию только один раз
  @@unique([userId, jobId]) 
}

model Application {
  id          String            @id @default(uuid())
  jobId       String
  job         Job               @relation(fields: [jobId], references: [id])

  candidateId String
  candidate   User              @relation("UserApplications", fields: [candidateId], references: [id])
 
  coverLetter String?
  cvUrl       String?
  status      String            @default("new") 

  lastViewedByCandidate DateTime @default(now())
  lastViewedByOwner     DateTime @default(now())

  createdAt   DateTime          @default(now())
  messages    Message[]
  
  @@unique([jobId, candidateId])
}

model Message {
  id            String      @id @default(uuid())
  applicationId String
  application   Application @relation(fields: [applicationId], references: [id])
  senderId      String
  text          String
  createdAt     DateTime    @default(now())
}